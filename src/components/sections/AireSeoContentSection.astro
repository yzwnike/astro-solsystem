---
// Copy SEO listo para maquetar (página 8 del boceto)
// 4 bloques de texto con H2 recomendados para posicionamiento orgánico.
const blocks = [
  {
    title: "Instaladores de aire acondicionado en Madrid",
    text: "En SolSystems, empresa de aire acondicionado en Madrid, realizamos el montaje e instalación de equipos para viviendas, oficinas y locales. Nuestro equipo analiza el espacio, la orientación, el uso de cada estancia y la instalación eléctrica existente para recomendarte una solución eficiente y segura.",
  },
  {
    title: "Presupuesto de aire acondicionado en 24 horas",
    text: "Cuéntanos qué necesitas y envíanos fotos del espacio. Te prepararemos una propuesta clara con equipo recomendado, alcance de instalación y plazos. Si es necesario, coordinamos visita técnica para cerrar el presupuesto.",
  },
  {
    title: "Instalación profesional, limpia y con garantía",
    text: "Cuidamos la ubicación de la unidad interior y exterior, la canalización, el desagüe, el aislamiento de tuberías y la protección eléctrica. Nuestro objetivo es que el equipo rinda bien desde el primer día y que la instalación quede integrada en tu vivienda o negocio.",
  },
  {
    title: "Soluciones eficientes para ahorrar energía",
    text: "Recomendamos equipos inverter y sistemas con bomba de calor cuando encajan con el uso del cliente. Una buena elección del equipo y una instalación correcta ayudan a mejorar el confort y controlar el consumo eléctrico.",
  },
];
---

<!-- ================= COPY SEO / CONTENIDO ================= -->
<section class="py-20 px-4 bg-slate-50 border-t border-slate-200">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-12">
      {blocks.map((block) => (
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3 flex items-start gap-3">
            <span class="w-1.5 h-6 bg-[#53C307] rounded-full flex-shrink-0 mt-1"></span>
            {block.title}
          </h2>
          <p class="text-slate-600 text-sm leading-relaxed pl-[18px]">{block.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
