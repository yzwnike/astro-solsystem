---
// Copy SEO (página 8 del boceto) con formato visual: imagen + bloques compactos.
import { CDN_IMAGES, type CityInfo } from '../../consts';

export interface Props {
  city?: CityInfo; // sin ciudad => landing general: no se nombra ninguna
}
const { city } = Astro.props;

const image = `${CDN_IMAGES}/aire4.webp`;

const blocks = [
  {
    title: city
      ? "Instaladores de aire acondicionado en Madrid y Barcelona"
      : "Instaladores de aire acondicionado con técnicos propios",
    text: "Empresa de aire acondicionado que analiza el espacio, la orientación y la instalación eléctrica existente para recomendarte la solución más eficiente y segura, en viviendas, oficinas y locales.",
  },
  {
    title: "Presupuesto en 24 horas",
    text: "Cuéntanos qué necesitas y envíanos fotos: preparamos una propuesta clara con equipo recomendado, alcance y plazos. Si hace falta, coordinamos visita técnica.",
  },
  {
    title: "Instalación profesional, limpia y con garantía",
    text: "Cuidamos la ubicación de las unidades, la canalización, el desagüe, el aislamiento y la protección eléctrica. Que el equipo rinda desde el primer día y quede integrado.",
  },
  {
    title: "Soluciones eficientes para ahorrar energía",
    text: "Equipos inverter y bomba de calor cuando encajan con tu uso. Una buena elección y una instalación correcta mejoran el confort y controlan el consumo eléctrico.",
  },
];
---

<!-- ================= COPY SEO / CONTENIDO (VISUAL) ================= -->
<section class="py-16 px-4 bg-slate-50 border-t border-slate-200">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
    <!-- Imagen -->
    <div class="relative rounded-3xl overflow-hidden shadow-xl border border-slate-200 order-1 lg:order-none">
      <img
        src={image}
        alt={city ? `Instalación de aire acondicionado split en vivienda en ${city.name} por SolSystems` : 'Instalación de aire acondicionado split en vivienda por SolSystems'}
        width="640"
        height="520"
        loading="lazy"
        class="w-full h-full max-h-[460px] object-cover"
      />
    </div>

    <!-- Bloques de texto compactos -->
    <div class="space-y-6">
      {blocks.map((block) => (
        <div>
          <h2 class="text-lg font-bold text-slate-900 mb-1.5 flex items-start gap-2.5">
            <span class="w-1.5 h-5 bg-[#53C307] rounded-full flex-shrink-0 mt-0.5"></span>
            {block.title}
          </h2>
          <p class="text-slate-600 text-sm leading-relaxed pl-4">{block.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
