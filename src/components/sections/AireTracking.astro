---
// Medición de conversiones (boceto pág. 10 y 12).
// Expone window.ssTrack(evento, params) que empuja a dataLayer (GTM) y a gtag (GA4/Ads)
// si están presentes. Delegación de clics para teléfono y WhatsApp.
//
// PENDIENTE POR PARTE DEL CLIENTE: pegar en BaseLayout <head> el snippet de GA4/GTM
// y, para Google Ads, sustituir los conversion IDs en los comentarios de abajo.
---

<script is:inline>
  window.dataLayer = window.dataLayer || [];

  // Helper único de tracking: funciona con GTM (dataLayer) y con GA4/Ads (gtag) si existen.
  window.ssTrack = function (eventName, params) {
    params = params || {};
    try {
      window.dataLayer.push(Object.assign({ event: eventName }, params));
    } catch (e) {}
    if (typeof window.gtag === 'function') {
      try { window.gtag('event', eventName, params); } catch (e) {}
      // Google Ads (descomentar y poner el conversion ID/label real):
      // window.gtag('event', 'conversion', { send_to: 'AW-XXXXXXXXX/label' });
    }
  };

  document.addEventListener('DOMContentLoaded', function () {
    // Clic en teléfono
    document.querySelectorAll('a[href^="tel:"]').forEach(function (el) {
      el.addEventListener('click', function () {
        window.ssTrack('contact_phone_click', { method: 'phone' });
      });
    });

    // Clic en WhatsApp
    document.querySelectorAll('a[href*="wa.me"], a[href*="api.whatsapp.com"]').forEach(function (el) {
      el.addEventListener('click', function () {
        window.ssTrack('contact_whatsapp_click', { method: 'whatsapp' });
      });
    });
  });
</script>
