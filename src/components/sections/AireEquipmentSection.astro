---
// Guía rápida de selección ("¿Qué aire acondicionado necesito según m²?").
const guide = [
  {
    space: "Dormitorio o despacho",
    system: "Split mural 1x1",
    power: "2.0 – 2.5 kW",
    advantage: "Ultra silencioso para dormir",
    icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z",
  },
  {
    space: "Salón mediano (< 35 m²)",
    system: "Split mural inverter",
    power: "3.5 – 4.2 kW",
    advantage: "Enfriamiento rápido del salón",
    icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
  },
  {
    space: "Vivienda completa",
    system: "Conductos",
    power: "7.1 – 10.0 kW",
    advantage: "Invisible, en falso techo",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  },
  {
    space: "Oficinas y locales",
    system: "Cassette en techo",
    power: "10.0 – 12.5 kW",
    advantage: "Distribución de aire a 360°",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
];
---

<!-- ================= TIPOS DE EQUIPO + GUÍA DE SELECCIÓN ================= -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">¿Qué aire acondicionado necesito según m²?</h2>
      <span class="block w-16 h-1 rounded-full bg-[#53C307] mx-auto mb-6"></span>
      <p class="text-slate-600">La potencia orientativa según tu espacio. En el estudio técnico ajustamos la elección al aislamiento, la orientación y el uso real.</p>
    </div>

    <!-- Guía de selección en tarjetas -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {guide.map((row) => (
        <div class="group relative flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:border-[#53C307]/40">
          <!-- Franja superior de color -->
          <div class="h-1.5 bg-gradient-to-r from-[#046bd2] to-[#53C307]"></div>

          <div class="p-6 flex flex-col flex-1">
            <!-- Icono + espacio -->
            <div class="flex items-center gap-3 mb-5">
              <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[#00AD2E] to-[#00BF33] text-white flex items-center justify-center flex-shrink-0 shadow-md shadow-[#00AD2E]/25">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={row.icon}/></svg>
              </div>
              <h3 class="text-sm font-bold text-slate-900 leading-tight">{row.space}</h3>
            </div>

            <!-- Potencia destacada -->
            <div class="mb-5">
              <span class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1">Potencia estimada</span>
              <span class="text-2xl font-extrabold text-slate-900 tracking-tight">{row.power}</span>
            </div>

            <!-- Sistema recomendado -->
            <div class="mb-5">
              <span class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Sistema recomendado</span>
              <span class="inline-block bg-slate-900 text-white text-xs font-semibold px-3 py-1.5 rounded-lg">{row.system}</span>
            </div>

            <!-- Ventaja principal -->
            <div class="mt-auto pt-4 border-t border-slate-100 flex items-start gap-2">
              <svg class="w-4 h-4 text-[#53C307] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-xs text-slate-600 leading-relaxed">{row.advantage}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
    <p class="text-slate-400 text-xs text-center mt-6">Valores orientativos. Calculamos las frigorías exactas en el estudio técnico gratuito.</p>
  </div>
</section>
