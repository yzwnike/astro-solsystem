---
// Hero: orientado a beneficio (instalación en 24-48h por técnicos propios),
// gancho de verano arriba, y específico por ciudad (Madrid / Barcelona).
import AireLeadForm from './AireLeadForm.astro';
import { CDN_IMAGES, type CityInfo } from '../../consts';

export interface Props {
  city?: CityInfo; // sin ciudad => copy general
}
const { city } = Astro.props;

const heroBg = `${CDN_IMAGES}/aire-acondicionado1.webp`;

const chips = [
  "Técnicos propios, sin subcontratas",
  "Instalación en 24-48 h",
  "Equipos eficientes A+++",
  "Garantía y postventa",
];
---

<!-- ================= HERO SECTION ================= -->
<section class="relative min-h-dvh flex items-center bg-slate-900 text-white overflow-hidden pt-28 pb-20 md:pt-32 px-4">
  <!-- Foto de fondo (CDN) -->
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroBg}');`}></div>
  <!-- Overlay oscuro para legibilidad del texto y el formulario -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/92 via-blue-950/88 to-slate-900/82"></div>
  <!-- Efecto visual de fondo (Abstract Shapes) -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,rgba(83,195,7,0.15),transparent_45%)]"></div>
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-600/10 rounded-full filter blur-3xl"></div>

  <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-10 lg:gap-12 items-center relative z-10">
    <!-- Texto Principal -->
    <div class="flex flex-col justify-center text-left">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-[1.1] tracking-tight mb-6">
        Tu <span class="text-[#53C307]">aire acondicionado</span> instalado en <span class="text-[#53C307]">24-48h</span> por técnicos propios{city ? ` en ${city.name}` : ''}
      </h1>
      <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl">
        Climatiza tu vivienda, oficina o local{city ? ` en ${city.name}` : ''} con nuestro equipo propio de técnicos, sin subcontratas. Estudio y presupuesto sin compromiso, e instalación en 24-48 horas.
      </p>

      <!-- Microcopy de confianza -->
      <div class="grid grid-cols-2 gap-4 mb-8">
        {chips.map((chip) => (
          <div class="flex items-center gap-2 text-sm text-slate-200">
            <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            {chip}
          </div>
        ))}
      </div>

      <!-- Botón de acción principal -->
      <div class="flex flex-wrap gap-4">
        <a href="#solicitar-presupuesto" class="bg-gradient-to-br from-[#00AD2E] to-[#00BF33] hover:from-[#009426] hover:to-[#00A52E] text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded-full shadow-lg shadow-[#00AD2E]/40 transition-all duration-300 hover:-translate-y-0.5">
          Quiero mi presupuesto gratis
        </a>
      </div>
    </div>

    <!-- Formulario principal (captación en el primer scroll) -->
    <div id="presupuesto-hero" class="relative">
      <div class="bg-white rounded-3xl shadow-2xl shadow-black/40 p-6 sm:p-8 border border-slate-200">
        <h2 class="text-xl font-bold text-slate-900 mb-1">Pide tu presupuesto gratis</h2>
        <p class="text-slate-500 text-sm mb-6">Estudio sin compromiso · Instalación en 24-48 h.</p>
        <AireLeadForm id="lead-form-hero" compact={false} submitLabel="Quiero mi presupuesto gratis" />
      </div>
    </div>
  </div>
</section>
