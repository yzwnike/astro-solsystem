---
// Bloque 1 del boceto: Hero + CTA
// Título SEO, propuesta de valor, "presupuesto en 24 h", llamada/WhatsApp
export interface Props {
  phone?: string;
  whatsapp?: string;
}

const {
  phone = "+34656701824",
  whatsapp = "+34656701824",
} = Astro.props;

const heroImage = import.meta.env.BASE_URL + "images/aire-acondicionado1.jpeg";
const waLink = `https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent("Hola, quiero pedir presupuesto para la instalación de aire acondicionado. Os envío unas fotos del espacio.")}`;
---

<!-- ================= HERO SECTION ================= -->
<section class="relative min-h-[90vh] flex items-center bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white overflow-hidden py-20 px-4">
  <!-- Efecto visual de fondo (Abstract Shapes) -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,rgba(83,195,7,0.15),transparent_45%)]"></div>
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-600/10 rounded-full filter blur-3xl"></div>

  <div class="max-w-6xl mx-auto w-full grid md:grid-cols-12 gap-12 items-center relative z-10">
    <!-- Texto Principal -->
    <div class="md:col-span-7 flex flex-col justify-center text-left">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Instalación de <span class="text-[#53C307]">aire acondicionado</span> en Madrid
      </h1>
      <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl">
        Climatiza tu vivienda, oficina o local con técnicos especialistas. Te asesoramos en el equipo más eficiente para tu espacio y te enviamos un presupuesto claro en 24 horas.
      </p>

      <!-- Microcopy de confianza -->
      <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="flex items-center gap-2 text-sm text-slate-200">
          <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Instalación profesional
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-200">
          <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Equipos eficientes
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-200">
          <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Asesoramiento técnico
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-200">
          <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Garantía y postventa
        </div>
      </div>

      <!-- Botones de Acción: CTA principal + CTA secundario (WhatsApp) -->
      <div class="flex flex-wrap gap-4">
        <a href="#solicitar-presupuesto" class="bg-[#53C307] hover:bg-[#45a006] text-white font-bold text-base px-8 py-4 rounded-xl shadow-lg shadow-[#53C307]/20 transition-all duration-300 hover:-translate-y-0.5">
          Solicitar presupuesto en 24 h
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold text-base px-6 py-4 rounded-xl transition-all duration-300">
          <svg class="w-5 h-5 fill-current text-[#25D366]" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.725 1.451 5.486 0 9.95-4.46 9.953-9.94 0-2.654-1.033-5.148-2.908-7.025C16.544 1.764 14.05 1.031 11.393 1.031 5.908 1.031 1.445 5.493 1.443 10.975c-.002 1.666.446 3.29 1.298 4.747L1.693 21.053l4.954-1.899z"/></svg>
          Enviar fotos por WhatsApp
        </a>
      </div>

      <!-- Teléfono directo visible en el primer scroll -->
      <a href={`tel:${phone.replace(/\s/g, "")}`} class="mt-6 inline-flex items-center gap-2 text-slate-300 hover:text-white text-sm w-fit transition-colors">
        <svg class="w-4 h-4 text-[#53C307]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        ¿Prefieres llamar? <span class="font-bold text-white">656 701 824</span>
      </a>
    </div>

    <!-- Visual sugerido: split instalado en vivienda moderna -->
    <div class="md:col-span-5 relative flex justify-center">
      <div class="relative w-full max-w-sm rounded-3xl overflow-hidden border border-slate-700 shadow-2xl shadow-black/50 bg-slate-800">
        <img
          src={heroImage}
          alt="Instalación de aire acondicionado split en vivienda en Madrid por SolSystems"
          width="400"
          height="320"
          loading="eager"
          class="w-full h-80 object-cover opacity-95"
        />
        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-slate-950 via-slate-900/60 to-transparent p-6 text-left">
          <p class="text-xs text-[#53C307] font-bold tracking-wider uppercase mb-1">Último proyecto</p>
          <h2 class="text-white font-bold text-base mb-1">Split Inverter instalado en Alcorcón</h2>
          <p class="text-slate-300 text-xs">Clase A+++ con integración de paneles solares.</p>
        </div>
      </div>
    </div>
  </div>
</section>
