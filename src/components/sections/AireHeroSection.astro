---
// Hero: orientado a beneficio (instalación en 24-48h por técnicos propios),
// gancho de verano arriba, y específico por ciudad (Madrid / Barcelona).
import AireLeadForm from './AireLeadForm.astro';
import { CDN_IMAGES, CITY_MADRID, type CityInfo } from '../../consts';

export interface Props {
  city?: CityInfo;
}
const { city = CITY_MADRID } = Astro.props;

const heroBg = `${CDN_IMAGES}/aire-acondicionado1.webp`;
const waLink = `https://wa.me/${city.whatsapp}?text=${encodeURIComponent("Hola, quiero pedir presupuesto para la instalación de aire acondicionado. Os envío unas fotos del espacio.")}`;

const chips = [
  "Técnicos propios, sin subcontratas",
  "Instalación en 24-48 h",
  "Equipos eficientes A+++",
  "Garantía y postventa",
];
---

<!-- ================= HERO SECTION ================= -->
<section class="relative min-h-[90vh] flex items-center bg-slate-900 text-white overflow-hidden py-20 px-4">
  <!-- Foto de fondo (CDN) -->
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroBg}');`}></div>
  <!-- Overlay oscuro para legibilidad del texto y el formulario -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/92 via-blue-950/88 to-slate-900/82"></div>
  <!-- Efecto visual de fondo (Abstract Shapes) -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,rgba(83,195,7,0.15),transparent_45%)]"></div>
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-600/10 rounded-full filter blur-3xl"></div>

  <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-10 lg:gap-12 items-center relative z-10">
    <!-- Texto Principal -->
    <div class="flex flex-col justify-center text-left">
      <span class="inline-flex items-center gap-2 bg-[#53C307]/15 text-[#53C307] font-bold text-xs uppercase tracking-wider px-3.5 py-1.5 rounded-full mb-6 w-fit border border-[#53C307]/20">
        <span class="w-2 h-2 bg-[#53C307] rounded-full animate-pulse"></span>
        Prepara tu casa para el verano · Instalación en 24-48 h
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Tu <span class="text-[#53C307]">aire acondicionado</span> instalado en <span class="text-[#53C307]">24-48h</span> por técnicos propios en {city.name}
      </h1>
      <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl">
        Climatiza tu vivienda, oficina o local en {city.name} con nuestro equipo propio de técnicos, sin subcontratas. Estudio y presupuesto sin compromiso, e instalación en 24-48 horas.
      </p>

      <!-- Microcopy de confianza -->
      <div class="grid grid-cols-2 gap-4 mb-8">
        {chips.map((chip) => (
          <div class="flex items-center gap-2 text-sm text-slate-200">
            <svg class="w-5 h-5 text-[#53C307] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            {chip}
          </div>
        ))}
      </div>

      <!-- Botones de Acción: CTA principal + CTA secundario (WhatsApp) -->
      <div class="flex flex-wrap gap-4">
        <a href="#solicitar-presupuesto" class="bg-gradient-to-br from-[#00AD2E] to-[#00BF33] hover:from-[#009426] hover:to-[#00A52E] text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded-full shadow-lg shadow-[#00AD2E]/40 transition-all duration-300 hover:-translate-y-0.5">
          Quiero mi presupuesto gratis
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold text-base px-6 py-4 rounded-xl transition-all duration-300">
          <svg class="w-5 h-5 fill-current text-[#25D366]" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.725 1.451 5.486 0 9.95-4.46 9.953-9.94 0-2.654-1.033-5.148-2.908-7.025C16.544 1.764 14.05 1.031 11.393 1.031 5.908 1.031 1.445 5.493 1.443 10.975c-.002 1.666.446 3.29 1.298 4.747L1.693 21.053l4.954-1.899z"/></svg>
          Enviar fotos por WhatsApp
        </a>
      </div>

      <!-- Teléfono directo de la ciudad -->
      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-slate-300 text-sm">
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-[#53C307]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          ¿Prefieres llamar?
        </span>
        <a href={`tel:${city.phone}`} class="inline-flex items-center gap-1.5 hover:text-white transition-colors">
          <span class="font-bold text-white">{city.phoneDisplay}</span>
        </a>
      </div>
    </div>

    <!-- Formulario principal (captación en el primer scroll) -->
    <div id="presupuesto-hero" class="relative">
      <div class="bg-white rounded-3xl shadow-2xl shadow-black/40 p-6 sm:p-8 border border-slate-200">
        <h2 class="text-xl font-bold text-slate-900 mb-1">Pide tu presupuesto gratis</h2>
        <p class="text-slate-500 text-sm mb-6">Estudio sin compromiso · Instalación en 24-48 h.</p>
        <AireLeadForm id="lead-form-hero" compact={false} submitLabel="Quiero mi presupuesto gratis" />
      </div>
    </div>
  </div>
</section>
