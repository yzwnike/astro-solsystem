---
// Formulario de captación reutilizable para la landing de aire.
// Se usa dos veces: variante "compact" en el hero y "full" al final.
// Un único handler delegado gestiona TODOS los formularios de la página,
// así ambos funcionan sin duplicar lógica ni el webhook.
export interface Props {
  id: string;
  compact?: boolean;
  webhook?: string;
  submitLabel?: string;
  dark?: boolean; // estilos para fondo oscuro (hero)
}

const {
  id,
  compact = false,
  webhook = "https://hook.eu2.make.com/yo3nlh4c9mhhspc3iupjg8jpkj7ir8dk",
  submitLabel = "Solicitar presupuesto en 24 h",
  dark = false,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;

// Clases de input según el fondo
const inputBase = "w-full rounded-none bg-transparent py-3 text-sm focus:outline-none transition-colors";
const inputCls = dark
  ? `${inputBase} border-b border-white/30 text-white placeholder-slate-400 focus:border-[#53C307]`
  : `${inputBase} border-b border-black text-slate-900 placeholder-slate-600 focus:border-[#53C307]`;
const labelCls = dark ? "text-slate-300" : "text-slate-700";
---

<form id={id} class="js-aire-lead-form space-y-4" data-webhook={webhook} data-base={baseUrl}>
  <input type="hidden" name="form_source" value="landing_aire" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <input type="text" name="name" placeholder="Nombre*" required class={inputCls} />
    <input type="tel" name="phone" inputmode="numeric" placeholder="Teléfono*" required class={inputCls} />
  </div>

  {!compact && (
    <input type="email" name="email" placeholder="Correo electrónico*" required class={inputCls} />
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <input type="text" name="postalCode" inputmode="numeric" placeholder={compact ? "Cód. postal / zona*" : "Código postal / zona*"} required class={inputCls} />
    {!compact && (
      <input type="text" name="rooms" placeholder="Nº de estancias o m² aprox." class={inputCls} />
    )}
    {compact && (
      <select name="system" class={inputCls}>
        <option value="Split mural 1x1">Split (1 estancia)</option>
        <option value="Multisplit">Multisplit</option>
        <option value="Conductos">Conductos</option>
        <option value="No lo sé">No lo sé</option>
      </select>
    )}
  </div>

  {!compact && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
      <div>
        <label class={`block text-xs font-semibold mb-2 ${labelCls}`}>Tipo de inmueble</label>
        <select name="propertyType" class={inputCls}>
          <option value="Vivienda">Vivienda</option>
          <option value="Local">Local</option>
          <option value="Oficina">Oficina</option>
        </select>
      </div>
      <div>
        <label class={`block text-xs font-semibold mb-2 ${labelCls}`}>¿Qué necesitas?</label>
        <select name="system" class={inputCls}>
          <option value="Split mural 1x1">Split mural individual</option>
          <option value="Multisplit">Multisplit (varias estancias)</option>
          <option value="Conductos">Centralizado por conductos</option>
          <option value="Cassette">Cassette (oficina / local)</option>
          <option value="Sustitución de equipo">Sustitución de equipo</option>
          <option value="Mantenimiento">Mantenimiento / revisión</option>
          <option value="No lo sé">No lo sé, necesito asesoramiento</option>
        </select>
      </div>
    </div>
  )}

  {!compact && (
    <div class="pt-2">
      <label class={`block text-xs font-semibold mb-2 ${labelCls}`}>¿Para cuándo lo necesitas?</label>
      <select name="urgency" class={inputCls}>
        <option value="Esta semana">Esta semana</option>
        <option value="Este mes">Este mes</option>
        <option value="Solo información">Solo información</option>
      </select>
    </div>
  )}

  {!compact && (
    <div class="pt-2">
      <label class={`block text-xs font-semibold mb-2 ${labelCls}`}>Fotos del espacio (opcional, acelera el presupuesto)</label>
      <input type="text" name="photosLink" placeholder="Pega aquí un enlace a tus fotos (Drive, Fotos…)" class={inputCls} />
    </div>
  )}

  <div class="flex items-start gap-2 pt-3">
    <input type="checkbox" name="acceptedTerms" required class="mt-1 flex-shrink-0" />
    <label class={`text-xs leading-tight ${dark ? "text-slate-300" : "text-slate-700"}`}>
      Acepto la <a href="https://solsystems.es/politica-de-privacidad/" target="_blank" rel="noopener" class="underline hover:text-[#53C307]">política de privacidad</a> para tramitar mi solicitud.
    </label>
  </div>

  <div class="pt-2">
    <button type="submit" class="js-form-submit w-full bg-gradient-to-br from-[#00AD2E] to-[#00BF33] hover:from-[#009426] hover:to-[#00A52E] text-white font-bold text-sm uppercase tracking-wide px-8 py-3.5 rounded-full shadow-lg shadow-[#00AD2E]/40 inline-flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5">
      <span class="js-form-submit-text">{submitLabel}</span>
    </button>
  </div>

  <div class="js-form-message hidden mt-2 p-3 rounded-lg text-sm text-center"></div>
</form>

<script is:inline>
  (function () {
    if (window.__aireFormBound) return;
    window.__aireFormBound = true;

    document.addEventListener('submit', async function (e) {
      var form = e.target.closest ? e.target.closest('.js-aire-lead-form') : null;
      if (!form) return;
      e.preventDefault();

      var webhook = form.getAttribute('data-webhook');
      var baseUrl = form.getAttribute('data-base') || '/';
      var btn = form.querySelector('.js-form-submit');
      var btnText = form.querySelector('.js-form-submit-text');
      var msg = form.querySelector('.js-form-message');
      var defaultLabel = btnText ? btnText.textContent : 'Enviar';

      function showMsg(text, type) {
        if (!msg) return;
        msg.textContent = text;
        msg.classList.remove('hidden', 'bg-red-100', 'text-red-800', 'bg-green-100', 'text-green-800');
        msg.classList.add(type === 'success' ? 'bg-green-100' : 'bg-red-100', type === 'success' ? 'text-green-800' : 'text-red-800');
      }
      function reset() {
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
        if (btnText) btnText.textContent = defaultLabel;
      }

      var fd = new FormData(form);
      var name = fd.get('name');
      var phone = fd.get('phone');
      var postalCode = fd.get('postalCode');
      var email = fd.get('email'); // puede no existir en el compacto
      var acceptedTerms = fd.get('acceptedTerms');

      if (!name || !phone || !postalCode || (form.querySelector('[name="email"]') && !email)) {
        showMsg('Por favor, completa todos los campos obligatorios.', 'error');
        return;
      }
      if (!acceptedTerms) {
        showMsg('Debes aceptar la política de privacidad.', 'error');
        return;
      }

      if (btn) { btn.disabled = true; btn.style.opacity = '0.7'; }
      if (btnText) btnText.textContent = 'Enviando...';
      if (msg) msg.classList.add('hidden');

      var propertyType = fd.get('propertyType') || 'No especificado';
      var system = fd.get('system') || 'No especificado';
      var urgency = fd.get('urgency') || 'No especificado';
      var rooms = fd.get('rooms') || 'No especificado';
      var photosLink = fd.get('photosLink') || 'No adjuntado';

      // Mismo webhook y mismas claves que index, + extras de aire; todo el detalle en message.
      var payload = {
        name: name,
        email: email || 'No especificado',
        phone: phone,
        address: 'CP/Zona: ' + postalCode + ' · Inmueble: ' + propertyType,
        timeFrame: 'No especificado',
        postalCode: postalCode,
        rooms: rooms,
        photosLink: photosLink,
        propertyType: propertyType,
        system: system,
        urgency: urgency,
        message: 'Solicitud de AIRE ACONDICIONADO — Inmueble: ' + propertyType + ' · Sistema: ' + system + ' · Urgencia: ' + urgency + ' · Tamaño: ' + rooms + ' · Fotos: ' + photosLink,
        acceptedTerms: 'Sí',
        formSource: 'Landing Aire Acondicionado Madrid (' + form.id + ')',
        timestamp: new Date().toISOString(),
        userAgent: navigator.userAgent
      };

      try {
        var res = await fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        if (res.ok) {
          if (typeof window.ssTrack === 'function') {
            window.ssTrack('generate_lead', { form: form.id, system: system, urgency: urgency });
          }
          showMsg('¡Gracias! Hemos recibido tu solicitud. Te enviaremos una propuesta en un plazo máximo de 24 horas laborables.', 'success');
          form.reset();
          setTimeout(function () { window.location.href = baseUrl + 'gracias'; }, 1400);
        } else {
          throw new Error('Server error');
        }
      } catch (err) {
        console.error('Error enviando formulario:', err);
        showMsg('Ocurrió un error al enviar. Por favor, llámanos o escríbenos por WhatsApp.', 'error');
        reset();
      }
    });

    // Limita teléfono y CP a dígitos
    document.addEventListener('input', function (e) {
      var t = e.target;
      if (!t.closest || !t.closest('.js-aire-lead-form')) return;
      if (t.name === 'phone') {
        t.value = t.value.replace(/\D/g, '').substring(0, 9);
      } else if (t.name === 'postalCode') {
        t.value = t.value.replace(/\D/g, '').substring(0, 5);
      }
    });
  })();
</script>
