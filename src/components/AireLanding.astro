---
// Cuerpo completo de la landing de aire acondicionado, parametrizado por ciudad.
// Se reutiliza en las páginas de Madrid y Barcelona pasando la CityInfo.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './layout/Header.astro';
import AireHeroSection from './sections/AireHeroSection.astro';
import AireBrandsSection from './sections/AireBrandsSection.astro';
import AireTrustSection from './sections/AireTrustSection.astro';
import AireServicesSection from './sections/AireServicesSection.astro';
import AireEquipmentSection from './sections/AireEquipmentSection.astro';
import AireSeoContentSection from './sections/AireSeoContentSection.astro';
import AireProcessSection from './sections/AireProcessSection.astro';
import AireFaqSection from './sections/AireFaqSection.astro';
import AireContactSection from './sections/AireContactSection.astro';
import AireStickyCta from './sections/AireStickyCta.astro';
import AireTestimonials from './sections/AireTestimonials.astro';
import { CITIES, AIRE_GENERAL_URL, type CityInfo } from '../consts';

export interface Props {
  city?: CityInfo; // sin ciudad => landing general
}
const { city } = Astro.props;

const title = city
  ? `Instalación de Aire Acondicionado en ${city.name} | Técnicos Propios en 24-48h | SolSystems`
  : `Instalación de Aire Acondicionado | Técnicos Propios en 24-48h | SolSystems`;
const description = city
  ? `Instaladores de aire acondicionado en ${city.name}: split, multisplit y conductos. Técnicos propios, sin subcontratas, e instalación en 24-48 h. Presupuesto gratis.`
  : `Instaladores de aire acondicionado: split, multisplit y conductos. Técnicos propios, sin subcontratas, e instalación en 24-48 h. Presupuesto gratis.`;

// Ficha de sede reutilizable: una sola en las landings de ciudad, las dos en la general.
const sedeSchema = (c: CityInfo) => ({
  "@type": "LocalBusiness",
  "name": `SolSystems · Aire acondicionado ${c.name}`,
  "image": "https://solsystems.es/images/logo.png",
  "url": c.url,
  "telephone": c.phone,
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": c.street,
    "addressLocality": c.locality,
    "addressRegion": c.region,
    "postalCode": c.postalCode,
    "addressCountry": "ES"
  },
  "areaServed": { "@type": "City", "name": c.name }
});

// Sin ciudad no cabe un LocalBusiness (exige una dirección concreta):
// se declara la organización con sus dos sedes.
const businessSchema = city
  ? { "@context": "https://schema.org", ...sedeSchema(city) }
  : {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SolSystems · Aire acondicionado",
      "image": "https://solsystems.es/images/logo.png",
      "url": AIRE_GENERAL_URL,
      "location": CITIES.map(sedeSchema)
    };

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Instalación de aire acondicionado",
  "provider": { "@type": "LocalBusiness", "name": "SolSystems" },
  "areaServed": city
    ? { "@type": "City", "name": city.name }
    : CITIES.map((c) => ({ "@type": "City", "name": c.name })),
  "description": city
    ? `Instalación de aire acondicionado split, multisplit y por conductos en ${city.name}, con técnicos propios e instalación en 24-48 horas.`
    : `Instalación de aire acondicionado split, multisplit y por conductos, con técnicos propios e instalación en 24-48 horas.`,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de aire acondicionado",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalación de aire acondicionado split 1x1" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalación multisplit" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Aire acondicionado por conductos" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sustitución de equipos antiguos" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento y revisión de aire acondicionado" } }
    ]
  }
};
---

<BaseLayout title={title} description={description} includeLegalizationCSS={false} useMontserrat={true}>
  <Header transparent={true} />

  <!-- 1. Hero + CTA -->
  <AireHeroSection city={city} />

  <!-- 2. Servicios -->
  <AireServicesSection />

  <!-- 3. Marcas, confianza y tipos de equipo -->
  <AireBrandsSection />
  <AireTrustSection />

  <AireEquipmentSection />

  <!-- 4. Instalación + proceso (secciones unificadas) -->
  <AireProcessSection city={city} />

  <!-- 5. SEO / FAQ -->
  <AireSeoContentSection city={city} />
  <AireFaqSection city={city} />

  <!-- Testimonios (Google + reseñas reales + experiencia) -->
  <AireTestimonials city={city} />

  <!-- 6. Formulario (solo datos de la ciudad) -->
  <AireContactSection city={city} />

  <!-- CTA persistente -->
  <AireStickyCta city={city} />

  <!-- Schema -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
</BaseLayout>
