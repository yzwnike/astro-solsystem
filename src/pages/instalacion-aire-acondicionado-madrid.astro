---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import AireHeroSection from '../components/sections/AireHeroSection.astro';
import AireBrandsSection from '../components/sections/AireBrandsSection.astro';
import AireTrustSection from '../components/sections/AireTrustSection.astro';
import AireServicesSection from '../components/sections/AireServicesSection.astro';
import AireEquipmentSection from '../components/sections/AireEquipmentSection.astro';
import AireSeoContentSection from '../components/sections/AireSeoContentSection.astro';
import AireProcessSection from '../components/sections/AireProcessSection.astro';
import AireFaqSection from '../components/sections/AireFaqSection.astro';
import AireContactSection from '../components/sections/AireContactSection.astro';
import AireStickyCta from '../components/sections/AireStickyCta.astro';
import AireTracking from '../components/sections/AireTracking.astro';
import AireVisualBand from '../components/sections/AireVisualBand.astro';

// SEO on-page (página 12 del boceto)
const title = "Instalación de Aire Acondicionado en Madrid | Presupuesto 24h | SolSystems";
const description = "Instaladores de aire acondicionado en Madrid. Split, multisplit y conductos. Asesoramiento técnico, instalación profesional y presupuesto en 24 h.";

const phone = "+34656701824";

// Schema: LocalBusiness + Service (el FAQPage se genera dentro de AireFaqSection)
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SolSystems",
  "image": "https://solsystems.es/images/logo.png",
  "url": "https://solsystems.es/instalacion-aire-acondicionado-madrid/",
  "telephone": phone,
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Físicas 40",
    "addressLocality": "Alcorcón",
    "addressRegion": "Madrid",
    "postalCode": "28923",
    "addressCountry": "ES"
  },
  "areaServed": {
    "@type": "City",
    "name": "Madrid"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Instalación de aire acondicionado",
  "provider": {
    "@type": "LocalBusiness",
    "name": "SolSystems"
  },
  "areaServed": {
    "@type": "City",
    "name": "Madrid"
  },
  "description": "Instalación de aire acondicionado split, multisplit y por conductos en Madrid, con asesoramiento técnico y presupuesto en 24 horas.",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de aire acondicionado",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalación de aire acondicionado split 1x1" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalación multisplit" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Aire acondicionado por conductos" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sustitución de equipos antiguos" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento y revisión de aire acondicionado" } }
    ]
  }
};
---

<BaseLayout title={title} description={description} includeLegalizationCSS={false}>
  <!-- Header corporativo (transparente para integrarse sobre el Hero) -->
  <Header transparent={true} />

  <!-- Medición de conversiones (teléfono, WhatsApp, formulario, página gracias) -->
  <AireTracking />

  <!-- 1. Hero + CTA -->
  <AireHeroSection phone={phone} whatsapp={phone} />

  <!-- 2. Servicios (Bloque 2 del boceto: justo después del Hero) -->
  <AireServicesSection />

  <!-- 3. Marcas, confianza y tipos de equipo -->
  <AireBrandsSection />
  <AireTrustSection />

  <!-- Línea separadora (degradado azul → verde, como la barra de las tarjetas) -->
  <div class="bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="h-1 rounded-full bg-gradient-to-r from-[#046bd2] to-[#53C307]"></div>
    </div>
  </div>

  <AireEquipmentSection />

  <!-- Banda visual + CTA -->
  <AireVisualBand />

  <!-- 4. Proceso (incluye CTA repetido antes del FAQ) -->
  <AireProcessSection />

  <!-- 5. SEO / FAQ -->
  <AireSeoContentSection />
  <AireFaqSection />

  <!-- 6. Formulario -->
  <AireContactSection phone={phone} />

  <!-- CTA persistente: barra inferior móvil + WhatsApp flotante -->
  <AireStickyCta phone={phone} whatsapp={phone} />

  <!-- Schema estructurado: LocalBusiness + Service -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
</BaseLayout>
